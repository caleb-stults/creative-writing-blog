---
import Layout from '../layouts/Layout.astro';
import { CONFIG } from '../config';
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';

// Fetch your collections
const stories = (await getCollection('stories')).sort((a, b) => b.data.publicationDate.valueOf() - a.data.publicationDate.valueOf());
const poetry = (await getCollection('poetry')).sort((a, b) => b.data.publicationDate.valueOf() - a.data.publicationDate.valueOf());
const misc = (await getCollection('misc')).sort((a, b) => b.data.publicationDate.valueOf() - a.data.publicationDate.valueOf());
---

<Layout title="Home">
    <section id="hero">
        <h1 class="solway-regular">Personal Writing</h1>
        <p>
            Welcome. This is a place for me to house my personal writing.
        </p>
    </section>

    <hr />

    <section class="posts-section">
        <h2 class="solway-regular">Stories</h2>
        <div class="posts-grid">
            {stories.map(post => (
                <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    publicationDate={post.data.publicationDate}
                    slug={post.slug}
                />
            ))}
        </div>
    </section>

    <section class="posts-section">
        <h2 class="solway-regular">Poetry</h2>
        <div class="posts-grid">
            {poetry.map(post => (
                <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    publicationDate={post.data.publicationDate}
                    slug={post.slug}
                />
            ))}
        </div>
    </section>

    <section class="posts-section">
        <h2 class="solway-regular">Miscellaneous</h2>
        <div class="posts-grid">
            {misc.map(post => (
                <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    publicationDate={post.data.publicationDate}
                    slug={post.slug}
                />
            ))}
        </div>
    </section>

    <style>
        .posts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1rem;
            margin: 2rem 0;
        }

        #hero {
            padding: 2rem 0;
        }

        #hero h1 {
            font-size: var(--step-4);
            margin-bottom: 1rem;
        }

        section {
            padding: 1.5rem 0;
        }

        section h2 {
            font-size: var(--step-2);
            font-weight: 600;
        }
    </style>
</Layout>